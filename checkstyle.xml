<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    This is an empty Checkstyle configuration.
    It contains no rules, so it will pass every project automatically.
    Use this as a placeholder to ensure the plugin is wired correctly.
-->

<module name="Checker">
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java, properties, xml"/>

    <!-- TreeWalker is required for most Java checks, but we leave it empty -->
    <module name="TreeWalker">
    </module>
</module>